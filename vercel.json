{
  "version": 2,
  "builds": [
    { "src": "landing/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/", "dest": "/landing/index.html" },
    { "src": "/mentori-express(/.*)?", "status": 308, "headers": { "Location": "/mentory-express/" } },
    { "src": "/(.*)", "dest": "/landing/$1" }
  ]
}
